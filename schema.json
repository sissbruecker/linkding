      - tokenAuth: []
      - cookieAuth: []
      - bearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BookmarkBundle'
          description: ''
    put:
      operationId: bundles_update
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - bundles
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BookmarkBundle'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/BookmarkBundle'
          multipart/form-data:
