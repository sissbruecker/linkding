      security:
      - tokenAuth: []
      - cookieAuth: []
      - bearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Tag'
          description: ''
  /api/user/profile/:
    get:
      operationId: user_profile_retrieve
      tags:
      - user
      security:
      - tokenAuth: []
      - cookieAuth: []
      - bearerAuth: []
      responses:
        '200':
          description: No response body
components:
  schemas:
    Bookmark:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        url:
          type: string
          format: uri
          maxLength: 2048
        title:
          type: string
          maxLength: 512
        description:
          type: string
        notes:
          type: string
        web_archive_snapshot_url:
          type: string
          readOnly: true
        favicon_url:
          type: string
          readOnly: true
        preview_image_url:
          type: string
          readOnly: true
        is_archived:
          type: boolean
        unread:
          type: boolean
        shared:
          type: boolean
        tag_names:
          type: array
          items:
            type: string
        date_added:
          type: string
          format: date-time
        date_modified:
          type: string
          format: date-time
        website_title:
          type: string
          nullable: true
          readOnly: true
        website_description:
          type: string
          nullable: true
          readOnly: true
      required:
      - favicon_url
      - id
      - preview_image_url
      - url
      - web_archive_snapshot_url
      - website_description
      - website_title
    BookmarkAsset:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        bookmark:
          type: integer
        date_created:
          type: string
          format: date-time
          readOnly: true
        file_size:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
          nullable: true
        asset_type:
          type: string
          maxLength: 64
        content_type:
          type: string
          maxLength: 128
        display_name:
          type: string
          maxLength: 2048
        status:
          type: string
          maxLength: 64
      required:
      - asset_type
      - bookmark
      - content_type
      - date_created
      - id
      - status
    BookmarkBundle:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 256
        search:
          type: string
          maxLength: 256
        any_tags:
          type: string
          maxLength: 1024
        all_tags:
          type: string
          maxLength: 1024
        excluded_tags:
          type: string
          maxLength: 1024
        filter_unread:
          $ref: '#/components/schemas/FilterUnreadEnum'
        filter_shared:
          $ref: '#/components/schemas/FilterSharedEnum'
        order:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
        date_created:
          type: string
          format: date-time
          readOnly: true
        date_modified:
          type: string
          format: date-time
          readOnly: true
      required:
      - date_created
      - date_modified
      - id
      - name
    FilterSharedEnum:
      enum:
      - 'off'
      - 'yes'
      - 'no'
      type: string
      description: |-
        * `off` - All
        * `yes` - Shared
        * `no` - Unshared
    FilterUnreadEnum:
      enum:
      - 'off'
      - 'yes'
      - 'no'
      type: string
      description: |-
        * `off` - All
        * `yes` - Unread
        * `no` - Read
    PaginatedBookmarkAssetList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=400&limit=100
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=200&limit=100
        results:
          type: array
          items:
            $ref: '#/components/schemas/BookmarkAsset'
    PaginatedBookmarkBundleList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=400&limit=100
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=200&limit=100
        results:
          type: array
          items:
            $ref: '#/components/schemas/BookmarkBundle'
    PaginatedBookmarkList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=400&limit=100
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=200&limit=100
        results:
          type: array
          items:
            $ref: '#/components/schemas/Bookmark'
    PaginatedTagList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=400&limit=100
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?offset=200&limit=100
        results:
          type: array
          items:
            $ref: '#/components/schemas/Tag'
    PatchedBookmark:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        url:
          type: string
          format: uri
          maxLength: 2048
        title:
          type: string
          maxLength: 512
        description:
          type: string
        notes:
          type: string
        web_archive_snapshot_url:
          type: string
          readOnly: true
        favicon_url:
          type: string
          readOnly: true
        preview_image_url:
          type: string
          readOnly: true
        is_archived:
          type: boolean
        unread:
          type: boolean
        shared:
          type: boolean
        tag_names:
          type: array
          items:
            type: string
        date_added:
          type: string
          format: date-time
        date_modified:
          type: string
          format: date-time
        website_title:
          type: string
          nullable: true
          readOnly: true
        website_description:
          type: string
          nullable: true
          readOnly: true
    PatchedBookmarkBundle:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 256
        search:
          type: string
          maxLength: 256
        any_tags:
          type: string
          maxLength: 1024
        all_tags:
          type: string
          maxLength: 1024
        excluded_tags:
          type: string
          maxLength: 1024
        filter_unread:
          $ref: '#/components/schemas/FilterUnreadEnum'
        filter_shared:
          $ref: '#/components/schemas/FilterSharedEnum'
        order:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
        date_created:
          type: string
          format: date-time
          readOnly: true
        date_modified:
          type: string
          format: date-time
          readOnly: true
    Tag:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 64
        date_added:
          type: string
          format: date-time
          readOnly: true
      required:
      - date_added
      - id
      - name
  securitySchemes:
    cookieAuth:
      type: apiKey
      in: cookie
      name: sessionid
    tokenAuth:
      type: apiKey
      in: header
      name: Authorization
      description: Token-based authentication with required prefix "Token"
