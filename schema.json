    patch:
      operationId: bundles_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - bundles
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedBookmarkBundle'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedBookmarkBundle'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedBookmarkBundle'
