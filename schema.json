        description: The initial index from which to return the results.
        schema:
          type: integer
      tags:
      - bundles
      security:
      - tokenAuth: []
      - cookieAuth: []
      - bearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedBookmarkBundleList'
          description: ''
    post:
      operationId: bundles_create
      tags:
      - bundles
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BookmarkBundle'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/BookmarkBundle'
          multipart/form-data:
